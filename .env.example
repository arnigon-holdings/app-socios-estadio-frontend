# API base URL (Rails backend)
VITE_API_BASE_URL=http://localhost:3000

# AWS region for the liveness API + Cognito
VITE_AWS_REGION=us-east-1

# Face Liveness API (AWS API Gateway) — used by Vite dev proxy in vite.config.ts
VITE_FACE_LIVENESS_API_URL=
VITE_FACE_LIVENESS_API_KEY=<your-aws-api-gateway-key>

# Cognito identity (used by Amplify SDK for credential vending)
VITE_COGNITO_IDENTITY_POOL_ID=<region>:<guid>
VITE_COGNITO_USER_POOL_ID=<region>_<alnum>
VITE_COGNITO_USER_POOL_CLIENT_ID=<alnum>
